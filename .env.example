# ──────────────────────────────────────────────────────────────────────────────
# HostDaddy.ai — Environment template
# Copy this to .env.local at the repo root. Never commit real values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Cloudflare (required for Phase 1) ────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=
KV_NAMESPACE_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hostdaddy-assets

# ── Auth (required for Phase 2) ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-32-byte-random-string

# ── Stripe (required for Phase 2) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Billplz (required for Phase 2 — Malaysian FPX/GrabPay/TNG) ───────────────
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE_KEY=

# ── Resend (required for Phase 2 — transactional email) ──────────────────────
RESEND_API_KEY=
RESEND_FROM=HostDaddy.ai <hello@hostdaddy.ai>

# ── MYNIC reseller via Exabytes (required for Phase 3 — .my domains) ─────────
EXABYTES_API_KEY=
EXABYTES_RESELLER_ID=

# ── Tawk.to live chat (Phase 7) ──────────────────────────────────────────────
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787
