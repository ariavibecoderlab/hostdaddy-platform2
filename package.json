{
  "name": "hostdaddy-platform",
  "version": "0.1.0",
  "private": true,
  "description": "HostDaddy.ai — domain registration, hosting, and AI-built websites on Cloudflare. White Unicorn Ventures.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @hostdaddy/db generate",
    "db:migrate": "pnpm --filter @hostdaddy/db migrate",
    "db:seed": "pnpm --filter @hostdaddy/db seed"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  }
}
