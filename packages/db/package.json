{
  "name": "@hostdaddy/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "wrangler d1 migrations apply hostdaddy-prod --remote",
    "migrate:local": "wrangler d1 migrations apply hostdaddy-prod --local",
    "seed": "tsx src/seed.ts",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.33.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240821.1",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.74.0"
  }
}
